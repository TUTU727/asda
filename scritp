-- =============================================
-- SISTEMA DE UI MODERNA
-- =============================================

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer
local mouse = player:GetMouse()

-- =============================================
-- CONFIGURACOES
-- =============================================

local config = {
    autoMerge = false,
    autoLocked = false,
    autoTier = false,
    autoSpawn = false,
    autoLockUpgrade = false,
    autoRebirth = false,
    autoKill = false,
    antiBan = true,
    selectedCommander = 1,
    mergeSpeed = 0.05,
}

-- =============================================
-- ANTI-BAN
-- =============================================

local antiBan = {
    history = {},
    maxHistory = 30,
}

function antiBan:randomDelay()
    if not config.antiBan then return 0 end
    local patterns = {0.05, 0.08, 0.12, 0.15, 0.2, 0.25}
    return patterns[math.random(#patterns)]
end

function antiBan:humanInterval()
    if not config.antiBan then return 0.1 end
    return math.random(5, 20) / 100
end

function antiBan:register(action)
    if not config.antiBan then return end
    table.insert(self.history, {action = action, time = tick()})
    if #self.history > self.maxHistory then
        table.remove(self.history, 1)
    end
end

-- =============================================
-- FUNCOES AUXILIARES
-- =============================================

local function findButton(pattern)
    local gui = player.PlayerGui
    for _, v in pairs(gui:GetDescendants()) do
        if v:IsA("TextButton") and v.Visible and v.Active then
            local name = v.Name:lower()
            local text = (v.Text or ""):lower()
            if name:find(pattern) or text:find(pattern) then
                return v
            end
        end
    end
    return nil
end

local function safeClick(button)
    if not button or not button:IsA("TextButton") then return false end
    if not button.Visible or not button.Active then return false end
    
    pcall(function()
        button:Activate()
    end)
    
    pcall(function()
        if button.ClickDetector then
            button.ClickDetector:FireClick()
        end
    end)
    
    antiBan:register("click_" .. button.Name)
    return true
end

-- =============================================
-- FUNCOES DE AUTOMACAO
-- =============================================

local function performMerge()
    if not config.autoMerge then return end
    
    local mergeBtn = findButton("merge")
    if mergeBtn then
        safeClick(mergeBtn)
        task.wait(antiBan:humanInterval())
        return
    end
    
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name:find("Nuke") then
            local click = v:FindFirstChild("ClickDetector")
            if click then
                pcall(function() 
                    click:FireClick() 
                    task.wait(antiBan:humanInterval() / 2)
                end)
            end
        end
    end
end

local function performLock()
    if not config.autoLocked then return end
    local lockBtn = findButton("lock")
    if lockBtn then
        safeClick(lockBtn)
        antiBan:register("lock")
    end
end

local function performTier()
    if not config.autoTier then return end
    local tierBtn = findButton("tier") or findButton("spawn tier")
    if tierBtn then
        safeClick(tierBtn)
        antiBan:register("tier")
        task.wait(antiBan:randomDelay())
    end
end

local function performSpawn()
    if not config.autoSpawn then return end
    local spawnBtn = findButton("spawn") or findButton("max spawn")
    if spawnBtn then
        safeClick(spawnBtn)
        antiBan:register("spawn")
        task.wait(antiBan:randomDelay())
    end
end

local function performLockUpgrade()
    if not config.autoLockUpgrade then return end
    local lockUpBtn = findButton("lock base") or findButton("base lock")
    if lockUpBtn then
        safeClick(lockUpBtn)
        antiBan:register("lock_upgrade")
        task.wait(antiBan:randomDelay())
    end
end

local function performRebirth()
    if not config.autoRebirth then return end
    local rebirthBtn = findButton("rebirth") or findButton("prestige")
    if rebirthBtn then
        safeClick(rebirthBtn)
        antiBan:register("rebirth")
        task.wait(antiBan:randomDelay() * 2)
    end
end

local function performKill()
    if not config.autoKill then return end
    
    local targets = {}
    
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") then
            local name = v.Name:lower()
            if name:find("commander") or name:find("boss") or name:find("chef") then
                local health = v:FindFirstChild("Health") or v:FindFirstChild("Humanoid")
                if health and health.Value > 0 then
                    table.insert(targets, v)
                end
            end
        end
    end
    
    for _, v in pairs(player.PlayerGui:GetDescendants()) do
        if v:IsA("TextButton") and v.Visible then
            local text = (v.Text or ""):lower()
            if text:find("commander") or text:find("boss") or text:find("attack") then
                table.insert(targets, v)
            end
        end
    end
    
    if #targets > 0 then
        local target = targets[math.min(config.selectedCommander, #targets)]
        if target:IsA("TextButton") then
            safeClick(target)
        elseif target:IsA("Model") then
            local click = target:FindFirstChild("ClickDetector")
            if click then
                pcall(function()
                    click:FireClick()
                    antiBan:register("kill_commander")
                end)
            end
        end
    end
end

-- =============================================
-- LOOP PRINCIPAL
-- =============================================

local function mainLoop()
    while task.wait() do
        local startTime = tick()
        
        if config.autoMerge then
            performMerge()
            task.wait(antiBan:humanInterval() / 2)
        end
        
        if config.autoLocked then
            performLock()
            task.wait(antiBan:humanInterval())
        end
        
        if config.autoTier then
            performTier()
            task.wait(antiBan:humanInterval())
        end
        
        if config.autoSpawn then
            performSpawn()
            task.wait(antiBan:humanInterval())
        end
        
        if config.autoLockUpgrade then
            performLockUpgrade()
            task.wait(antiBan:humanInterval())
        end
        
        if config.autoRebirth then
            performRebirth()
            task.wait(antiBan:humanInterval() * 1.5)
        end
        
        if config.autoKill then
            performKill()
            task.wait(antiBan:humanInterval() * 2)
        end
        
        local elapsed = tick() - startTime
        if elapsed < 0.05 then
            task.wait(0.05 - elapsed)
        end
    end
end

