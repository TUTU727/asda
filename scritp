-- =============================================
-- SISTEMA DE TELEPORTE PARA MERGE
-- =============================================

local function getNukes()
    local nukes = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local name = (obj.Name or ""):lower()
            if name:find("nuke") or name:find("bomb") or name:find("merge") or name:find("nuclear") then
                local primary = obj:FindFirstChild("PrimaryPart") or obj:FindFirstChild("HumanoidRootPart")
                if primary then
                    table.insert(nukes, {
                        model = obj,
                        part = primary,
                        position = primary.Position,
                        size = primary.Size,
                    })
                end
            end
        end
    end
    return nukes
end

local function getPlayerNukes()
    local nukes = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local name = (obj.Name or ""):lower()
            if name:find("nuke") or name:find("bomb") then
                local primary = obj:FindFirstChild("PrimaryPart") or obj:FindFirstChild("HumanoidRootPart")
                if primary then
                    -- Verifica se a nuke pertence ao jogador
                    local owner = obj:FindFirstChild("Owner") or obj:FindFirstChild("Player")
                    if owner and owner.Value == player then
                        table.insert(nukes, {
                            model = obj,
                            part = primary,
                            position = primary.Position,
                        })
                    end
                end
            end
        end
    end
    return nukes
end

local function teleportToNuke(nukePosition)
    if not config.teleportEnabled then return false end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    
    -- Calcula posicao segura perto da nuke
    local targetPos = nukePosition + Vector3.new(
        math.random(-3, 3),
        2,
        math.random(-3, 3)
    )
    
    -- Teleporta o jogador
    pcall(function()
        rootPart.CFrame = CFrame.new(targetPos)
        return true
    end)
    
    return true
end

local function findAndMergeNukes()
    if not config.autoMerge then return end
    
    -- Busca todas as nukes
    local nukes = getNukes()
    if #nukes < 2 then return end
    
    -- Agrupa nukes por nivel (se possivel)
    local groupedNukes = {}
    for _, nuke in pairs(nukes) do
        local level = 0
        -- Tenta extrair nivel do nome ou atributo
        local name = nuke.model.Name:lower()
        local levelMatch = name:match("level(%d+)") or name:match("lv(%d+)")
        if levelMatch then
            level = tonumber(levelMatch) or 0
        end
        
        if not groupedNukes[level] then
            groupedNukes[level] = {}
        end
        table.insert(groupedNukes[level], nuke)
    end
    
    -- Procura o grupo com mais nukes para merge
    local targetLevel = nil
    local maxCount = 0
    for level, group in pairs(groupedNukes) do
        if #group > maxCount and #group >= 2 then
            maxCount = #group
            targetLevel = level
        end
    end
    
    if targetLevel == nil or maxCount < 2 then return end
    
    local targetNukes = groupedNukes[targetLevel]
    local primaryNuke = targetNukes[1]
    
    -- Teleporta para a nuke primaria
    if config.teleportEnabled then
        teleportToNuke(primaryNuke.position)
        task.wait(0.1)
    end
    
    -- Clica na nuke primaria para iniciar merge
    local clickDetector = primaryNuke.model:FindFirstChild("ClickDetector")
    if clickDetector then
        pcall(function()
            clickDetector:FireClick()
        end)
    end
    
    -- Clica no botao de merge na interface
    pcall(function()
        clickPattern("merge", false)
    end)
    
    -- Tenta clicar nas outras nukes do mesmo nivel
    for i = 2, math.min(#targetNukes, 3) do
        local nuke = targetNukes[i]
        if nuke and nuke.model then
            local detector = nuke.model:FindFirstChild("ClickDetector")
            if detector then
                pcall(function()
                    detector:FireClick()
                end)
                task.wait(0.05)
            end
        end
    end
end

-- =============================================
-- FUNCOES DE CLICK CORRIGIDAS
-- =============================================

local function clickButton(button)
    if not button then return false end
    
    local success = false
    
    -- Metodo 1: Activate
    pcall(function()
        if button:IsA("TextButton") then
            button:Activate()
            success = true
        end
    end)
    
    -- Metodo 2: FireClickDetector
    pcall(function()
        local detector = button:FindFirstChild("ClickDetector")
        if detector then
            detector:FireClick()
            success = true
        end
    end)
    
    -- Metodo 3: FireServer
    pcall(function()
        if button.FireServer then
            button:FireServer()
            success = true
        end
    end)
    
    -- Metodo 4: Simular clique
    if not success then
        pcall(function()
            local pos = button.AbsolutePosition
            local size = button.AbsoluteSize
            virtualInput:SendMouseButtonEvent(
                pos.X + size.X/2,
                pos.Y + size.Y/2,
                0,
                true,
                game,
                0
            )
            task.wait(0.05)
            virtualInput:SendMouseButtonEvent(
                pos.X + size.X/2,
                pos.Y + size.Y/2,
                0,
                false,
                game,
                0
            )
            success = true
        end)
    end
    
    return success
end

local function findButtonByText(pattern)
    pattern = pattern:lower()
    local results = {}
    
    for _, screenGui in pairs(player.PlayerGui:GetChildren()) do
        if screenGui:IsA("ScreenGui") and screenGui.Enabled then
            for _, button in pairs(screenGui:GetDescendants()) do
                if button:IsA("TextButton") and button.Visible and button.Active then
                    local text = (button.Text or ""):lower()
                    local name = (button.Name or ""):lower()
                    
                    if text:find(pattern) or name:find(pattern) then
                        table.insert(results, button)
                    end
                end
            end
        end
    end
    
    return results
end

local function clickPattern(pattern)
    local buttons = findButtonByText(pattern)
    for _, btn in pairs(buttons) do
        if clickButton(btn) then
            return true
        end
    end
    return false
end

-- =============================================
-- FUNCOES DE AUTOMACAO
-- =============================================

local function doMerge()
    if not config.autoMerge then return end
    
    -- Metodo principal: Sistema de teleporte
    findAndMergeNukes()
    
    -- Fallback: Clique no botao merge da UI
    clickPattern("merge")
    
    -- Fallback: Clique central
    local viewportSize = workspace.CurrentCamera.ViewportSize
    virtualInput:SendMouseButtonEvent(
        viewportSize.X/2,
        viewportSize.Y/2 + 50,
        0,
        true,
        game,
        0
    )
    task.wait(0.05)
    virtualInput:SendMouseButtonEvent(
        viewportSize.X/2,
        viewportSize.Y/2 + 50,
        0,
        false,
        game,
        0
    )
end

local function doLocked()
    if not config.autoLocked then return end
    clickPattern("lock") or clickPattern("shield")
end

local function doTier()
    if not config.autoTier then return end
    clickPattern("tier") or clickPattern("spawn tier") or clickPattern("upgrade tier")
end

local function doSpawn()
    if not config.autoSpawn then return end
    clickPattern("spawn") or clickPattern("max spawn") or clickPattern("spawn rate")
end

local function doLockUpgrade()
    if not config.autoLockUpgrade then return end
    clickPattern("lock base") or clickPattern("base lock") or clickPattern("lock upgrade")
end

local function doRebirth()
    if not config.autoRebirth then return end
    clickPattern("rebirth") or clickPattern("prestige") or clickPattern("reset")
end

local function doKill()
    if not config.autoKill then return end
    
    local killed = false
    
    -- Procura comandantes no workspace
    local commanders = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local name = (obj.Name or ""):lower()
            if name:find("commander") or name:find("boss") or name:find("chef") or name:find("lider") then
                local health = obj:FindFirstChild("Health") or obj:FindFirstChild("Humanoid")
                if health and health.Value > 0 then
                    table.insert(commanders, obj)
                end
            end
        end
    end
    
    if #commanders > 0 then
        local target = commanders[math.min(config.selectedCommander, #commanders)]
        local detector = target:FindFirstChild("ClickDetector")
        if detector then
            pcall(function()
                detector:FireClick()
                killed = true
            end)
        end
    end
    
    if not killed then
        clickPattern("attack") or clickPattern("commander") or clickPattern("boss")
    end
end

-- =============================================
-- LOOP PRINCIPAL
-- =============================================

local function getDelay()
    return math.random(3, 8) / 100
end

local function getPause()
    return math.random(5, 15) / 10
end

local function mainLoop()
    while running do
        task.wait(getDelay())
        
        if config.autoMerge then
            doMerge()
            task.wait(getDelay())
        end
        
        if config.autoLocked then
            doLocked()
            task.wait(getDelay())
        end
        
        if config.autoTier then
            doTier()
            task.wait(getDelay())
        end
        
        if config.autoSpawn then
            doSpawn()
            task.wait(getDelay())
        end
        
        if config.autoLockUpgrade then
            doLockUpgrade()
            task.wait(getDelay())
        end
        
        if config.autoRebirth then
            doRebirth()
            task.wait(getPause())
        end
        
        if config.autoKill then
            doKill()
            task.wait(getPause())
        end
    end
end

