-- =============================================
-- FUNCAO PARA CLICAR EM BOTOES (CORRIGIDA)
-- =============================================

local function clickButton(button)
    if not button then return false end
    
    local success = false
    
    -- Metodo 1: Activate
    pcall(function()
        if button:IsA("TextButton") then
            button:Activate()
            success = true
        end
    end)
    
    -- Metodo 2: FireClickDetector
    pcall(function()
        local detector = button:FindFirstChild("ClickDetector")
        if detector then
            detector:FireClick()
            success = true
        end
    end)
    
    -- Metodo 3: FireServer
    pcall(function()
        if button.FireServer then
            button:FireServer()
            success = true
        end
    end)
    
    -- Metodo 4: Simular clique na posicao
    if not success then
        pcall(function()
            local pos = button.AbsolutePosition
            local size = button.AbsoluteSize
            virtualInput:SendMouseButtonEvent(
                pos.X + size.X/2,
                pos.Y + size.Y/2,
                0,
                true,
                game,
                0
            )
            task.wait(0.05)
            virtualInput:SendMouseButtonEvent(
                pos.X + size.X/2,
                pos.Y + size.Y/2,
                0,
                false,
                game,
                0
            )
            success = true
        end)
    end
    
    return success
end

-- =============================================
-- FUNCAO PARA ENCONTRAR BOTOES
-- =============================================

local function findButtonByText(pattern, exact)
    pattern = pattern:lower()
    local results = {}
    
    -- Procura em todas as interfaces
    for _, screenGui in pairs(player.PlayerGui:GetChildren()) do
        if screenGui:IsA("ScreenGui") and screenGui.Enabled then
            for _, button in pairs(screenGui:GetDescendants()) do
                if button:IsA("TextButton") and button.Visible and button.Active then
                    local text = (button.Text or ""):lower()
                    local name = (button.Name or ""):lower()
                    
                    if exact then
                        if text == pattern or name == pattern then
                            table.insert(results, button)
                        end
                    else
                        if text:find(pattern) or name:find(pattern) then
                            table.insert(results, button)
                        end
                    end
                end
            end
        end
    end
    
    return results
end

local function clickPattern(pattern, exact)
    local buttons = findButtonByText(pattern, exact)
    for _, btn in pairs(buttons) do
        if clickButton(btn) then
            return true
        end
    end
    return false
end

-- =============================================
-- FUNCOES DE AUTOMACAO (CORRIGIDAS)
-- =============================================

local function doMerge()
    if not config.autoMerge then return end
    
    -- Tenta encontrar e clicar no botao de merge
    local merged = clickPattern("merge", false)
    
    if not merged then
        -- Tenta clicar em nukes no workspace
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Model") then
                local name = obj.Name:lower()
                if name:find("nuke") or name:find("bomb") or name:find("merge") then
                    local detector = obj:FindFirstChild("ClickDetector")
                    if detector then
                        pcall(function()
                            detector:FireClick()
                            merged = true
                        end)
                    end
                end
            end
        end
    end
    
    if not merged then
        -- Tenta clicar no centro da tela (onde geralmente esta o botao)
        local viewportSize = workspace.CurrentCamera.ViewportSize
        virtualInput:SendMouseButtonEvent(
            viewportSize.X/2,
            viewportSize.Y/2 + 50,
            0,
            true,
            game,
            0
        )
        task.wait(0.05)
        virtualInput:SendMouseButtonEvent(
            viewportSize.X/2,
            viewportSize.Y/2 + 50,
            0,
            false,
            game,
            0
        )
    end
end

local function doLocked()
    if not config.autoLocked then return end
    
    local locked = clickPattern("lock", false)
    if not locked then
        locked = clickPattern("shield", false)
    end
    if not locked then
