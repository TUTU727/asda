-- =============================================
-- AUTO KILL COMMANDER
-- =============================================

local function doKillCommander()
    if not config.autoKill then return end
    
    local killed = false
    
    -- Método 1: Procurar comandantes no workspace
    local commanders = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") then
            local name = (v.Name or ""):lower()
            if name:find("commander") or name:find("boss") or name:find("chef") or name:find("enemy") then
                local health = v:FindFirstChild("Health") or v:FindFirstChild("Humanoid")
                if health and health.Value > 0 then
                    table.insert(commanders, v)
                end
            end
        end
    end
    
    if #commanders > 0 then
        local target = commanders[math.min(config.selectedCommander, #commanders)]
        local click = target:FindFirstChild("ClickDetector")
        if click then
            pcall(function()
                click:FireClick()
                killed = true
            end)
        end
    end
    
    -- Método 2: Procurar botão de ataque na UI
    if not killed then
        killed = findAndClick("attack")
    end
    
    if not killed then
        killed = findAndClick("commander")
    end
    
    if not killed then
        killed = findAndClick("boss")
    end
    
    -- Método 3: Clique na posição do comandante na tela
    if not killed then
        local viewport = game:GetService("GuiService"):GetGuiInset()
        local centerX = viewport.X / 2
        local centerY = viewport.Y / 2
        clickOnScreen(centerX, centerY - 100)
    end
end

-- =============================================
-- LOOP PRINCIPAL COM ANTI-BAN
-- =============================================

local lastActions = {}
local function getRandomDelay()
    if not config.antiBan then return 0.02 end
    local delays = {0.05, 0.08, 0.12, 0.15, 0.2, 0.25, 0.3, 0.1, 0.18, 0.22}
    return delays[math.random(#delays)]
end

local function getRandomPause()
    if not config.antiBan then return 0.1 end
    local pauses = {0.5, 0.8, 1.0, 1.2, 1.5, 0.3, 0.7, 1.1}
    return pauses[math.random(#pauses)]
end

local function shouldRun()
    if not config.antiBan then return true end
    -- 95% de chance de executar (simula pausas humanas)
    return math.random() < 0.95
end

local function mainLoop()
    while task.wait(getRandomDelay()) do
        if not shouldRun() then 
            task.wait(getRandomPause())
            continue 
        end
        
        -- Auto Merge
        if config.autoMerge then
            doAutoMerge()
            task.wait(getRandomDelay())
        end
        
        -- Auto Locked
        if config.autoLocked then
            doAutoLocked()
            task.wait(getRandomDelay())
        end
        
        -- Auto Tier Upgrade
        if config.autoTier then
            doTierUpgrade()
            task.wait(getRandomDelay())
        end
        
        -- Auto Spawn Upgrade
        if config.autoSpawn then
            doSpawnUpgrade()
            task.wait(getRandomDelay())
        end
        
        -- Auto Lock Upgrade
        if config.autoLockUpgrade then
            doLockUpgrade()
            task.wait(getRandomDelay())
        end
        
        -- Auto Rebirth
        if config.autoRebirth then
            doRebirth()
            task.wait(getRandomDelay() * 2)
        end
        
        -- Auto Kill Commander
        if config.autoKill then
            doKillCommander()
            task.wait(getRandomDelay() * 1.5)
        end
    end
end

