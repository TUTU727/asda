local function doRebirth()
    if not config.autoRebirth then return end
    
    local rebirthed = clickPattern("rebirth", false)
    if not rebirthed then
        rebirthed = clickPattern("prestige", false)
    end
    if not rebirthed then
        rebirthed = clickPattern("reset", false)
    end
    if not rebirthed then
        rebirthed = clickPattern("renascer", false)
    end
end

local function doKill()
    if not config.autoKill then return end
    
    local killed = false
    
    -- Procura comandantes no workspace
    local commanders = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local name = obj.Name:lower()
            if name:find("commander") or name:find("boss") or name:find("chef") or name:find("lider") then
                local health = obj:FindFirstChild("Health") or obj:FindFirstChild("Humanoid")
                if health and health.Value > 0 then
                    table.insert(commanders, obj)
                end
            end
        end
    end
    
    if #commanders > 0 then
        local target = commanders[math.min(config.selectedCommander, #commanders)]
        local detector = target:FindFirstChild("ClickDetector")
        if detector then
            pcall(function()
                detector:FireClick()
                killed = true
            end)
        end
    end
    
    -- Tenta via interface
    if not killed then
        killed = clickPattern("attack", false)
    end
    if not killed then
        killed = clickPattern("commander", false)
    end
    if not killed then
        killed = clickPattern("boss", false)
    end
    if not killed then
        killed = clickPattern("atacar", false)
    end
end

-- =============================================
-- LOOP PRINCIPAL
-- =============================================

local function getDelay()
    if not config.antiBan then return 0.02 end
    local delays = {0.03, 0.05, 0.08, 0.1, 0.12, 0.15, 0.18, 0.2}
    return delays[math.random(#delays)]
end

local function getPause()
    if not config.antiBan then return 0.1 end
    local pauses = {0.3, 0.5, 0.7, 0.8, 1.0, 1.2, 1.5}
    return pauses[math.random(#pauses)]
end

local function mainLoop()
    while running do
        task.wait(getDelay())
        
        -- Executa funcoes em ordem com pausas
        if config.autoMerge then
            doMerge()
            task.wait(getDelay())
        end
        
        if config.autoLocked then
            doLocked()
            task.wait(getDelay())
        end
        
        if config.autoTier then
            doTier()
            task.wait(getDelay())
        end
        
        if config.autoSpawn then
            doSpawn()
            task.wait(getDelay())
        end
        
        if config.autoLockUpgrade then
            doLockUpgrade()
            task.wait(getDelay())
        end
        
        if config.autoRebirth then
            doRebirth()
            task.wait(getPause())
        end
        
        if config.autoKill then
            doKill()
            task.wait(getPause())
        end
    end
end

