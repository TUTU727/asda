-- =============================================
-- FUNCOES DE CLICK UNIVERSAL
-- =============================================

local function findAndClick(pattern, multiple)
    local clicked = false
    local gui = player:WaitForChild("PlayerGui")
    
    -- Procura em todos os frames do jogo
    for _, v in pairs(gui:GetDescendants()) do
        if v:IsA("TextButton") and v.Visible and v.Active then
            local name = (v.Name or ""):lower()
            local text = (v.Text or ""):lower()
            
            if name:find(pattern) or text:find(pattern) then
                pcall(function()
                    -- Tenta diferentes métodos de clique
                    v:Activate()
                    if v.ClickDetector then
                        v.ClickDetector:FireClick()
                    end
                    -- FireServer para botões com servidor
                    if v.FireServer then
                        v:FireServer()
                    end
                    clicked = true
                end)
                if not multiple then break end
            end
        end
    end
    
    -- Procura em modelos no workspace
    if not clicked then
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") and v:FindFirstChild("ClickDetector") then
                local name = (v.Name or ""):lower()
                if name:find(pattern) then
                    pcall(function()
                        v.ClickDetector:FireClick()
                        clicked = true
                    end)
                    if not multiple then break end
                end
            end
        end
    end
    
    return clicked
end

local function clickOnScreen(x, y)
    -- Simula clique na tela em posição específica
    local vim = game:GetService("VirtualInputManager")
    vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.05)
    vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
end

-- =============================================
-- FUNCAO PARA ENCONTRAR BOTOES PELA COR
-- =============================================

local function findButtonByColor(color, radius)
    -- Procura botões por cor aproximada
    local results = {}
    local gui = player:WaitForChild("PlayerGui")
    
    for _, v in pairs(gui:GetDescendants()) do
        if v:IsA("TextButton") and v.Visible then
            local bg = v.BackgroundColor3
            local diff = math.abs(bg.R - color.R) + math.abs(bg.G - color.G) + math.abs(bg.B - color.B)
            if diff < (radius or 0.3) then
                table.insert(results, v)
            end
        end
    end
    return results
end

-- =============================================
-- AUTO MERGE (FAST)
-- =============================================

local function doAutoMerge()
    if not config.autoMerge then return end
    
    -- Método 1: Clica no botão de merge da interface
    local merged = findAndClick("merge")
    
    if not merged then
        -- Método 2: Clica nas nukes diretamente no mundo
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") and (v.Name:lower():find("nuke") or v.Name:lower():find("bomb")) then
                local click = v:FindFirstChild("ClickDetector")
                if click then
                    pcall(function()
                        click:FireClick()
                        merged = true
                    end)
                end
            end
        end
    end
    
    if not merged then
        -- Método 3: Clica no centro da tela (onde geralmente fica o botão)
        local viewport = game:GetService("GuiService"):GetGuiInset()
        local centerX = viewport.X / 2
        local centerY = viewport.Y / 2
        clickOnScreen(centerX, centerY + 50)
    end
end

