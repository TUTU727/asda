-- ========== ESP ==========
local function CreateESP(player)
    if player == LocalPlayer or not player.Character then return end
    
    local char = player.Character
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not root or not head then return end
    
    -- BOX
    local box = Drawing.new("Square")
    box.Thickness = 2
    box.Filled = false
    box.Transparency = 0.4
    box.Color = Color3.new(1, 1, 1)
    box.Visible = false
    table.insert(espObjects, box)
    
    -- HEALTH
    local health = Drawing.new("Square")
    health.Thickness = 0
    health.Filled = true
    health.Transparency = 0.5
    health.Visible = false
    table.insert(espObjects, health)
    
    -- NAME
    local name = Drawing.new("Text")
    name.Size = 14
    name.Center = true
    name.Color = Color3.new(1, 1, 1)
    name.Visible = false
    name.Font = 3
    table.insert(espObjects, name)
    
    -- DISTANCE
    local dist = Drawing.new("Text")
    dist.Size = 12
    dist.Center = true
    dist.Color = Color3.new(1, 1, 1)
    dist.Visible = false
    dist.Font = 2
    table.insert(espObjects, dist)
    
    -- LINE
    local line = Drawing.new("Line")
    line.Thickness = 3
    line.Color = Color3.new(1, 1, 1)
    line.Transparency = 0.3
    line.Visible = false
    table.insert(espObjects, line)
    
    -- SKELETON
    local skeletonLines = {}
    local joints = {
        {"Head", "UpperTorso"},
        {"UpperTorso", "LowerTorso"},
        {"UpperTorso", "LeftUpperArm"},
        {"LeftUpperArm", "LeftLowerArm"},
        {"UpperTorso", "RightUpperArm"},
        {"RightUpperArm", "RightLowerArm"},
        {"LowerTorso", "LeftUpperLeg"},
        {"LeftUpperLeg", "LeftLowerLeg"},
        {"LowerTorso", "RightUpperLeg"},
        {"RightUpperLeg", "RightLowerLeg"}
    }
    
    for _, joint in pairs(joints) do
        local lineObj = Drawing.new("Line")
        lineObj.Thickness = 3
        lineObj.Color = Color3.new(1, 1, 1)
        lineObj.Transparency = 0.3
        lineObj.Visible = false
        table.insert(espObjects, lineObj)
        table.insert(skeletonLines, {
            line = lineObj,
            part1 = joint[1],
            part2 = joint[2]
        })
    end
    
    -- UPDATE
    local function UpdateESP()
        if not Config.esp or not char or not char.Parent then
            box.Visible = false
            health.Visible = false
            name.Visible = false
            dist.Visible = false
            line.Visible = false
            for _, joint in pairs(skeletonLines) do
                joint.line.Visible = false
            end
            return
        end
        
        if Config.streamerMode then
            box.Visible = false
            health.Visible = false
            name.Visible = false
            dist.Visible = false
            line.Visible = false
            for _, joint in pairs(skeletonLines) do
                joint.line.Visible = false
            end
            return
        end
        
        local hp, on = Camera:WorldToViewportPoint(head.Position)
        local rp = Camera:WorldToViewportPoint(root.Position)
        
        if on and hp.Z > 0 then
            local height = math.abs(hp.Y - rp.Y) * 2.3
            local width = height * 0.45
            local cx = hp.X
            local ty = hp.Y - height
            
            if Config.espBox then
                box.Visible = true
                box.Size = Vector2.new(width, height)
                box.Position = Vector2.new(cx - width/2, ty)
                box.Color = Color3.new(1, 1, 1)
                box.Thickness = 2
                box.Transparency = 0.4
            else
                box.Visible = false
            end
            
            if Config.espHealth then
                health.Visible = true
                local percent = math.max(0, math.min(1, hum.Health / hum.MaxHealth))
                local bh = height * percent
                health.Size = Vector2.new(4, math.max(1, bh))
                health.Position = Vector2.new(cx + width/2 + 4, ty + (height - bh))
                health.Color = Color3.new(1 - percent, percent, 0)
            else
                health.Visible = false
            end
            
            if Config.espName then
                name.Visible = true
                name.Position = Vector2.new(cx, ty - 16)
                name.Text = player.Name
                name.Color = Color3.new(1, 1, 1)
            else
                name.Visible = false
            end
            
            if Config.espDistance then
                dist.Visible = true
                local distance = (root.Position - Camera.CFrame.Position).Magnitude / 10
                dist.Position = Vector2.new(cx, ty + height + 14)
                dist.Text = string.format("%.1fm", distance)
                dist.Color = Color3.new(1, 1, 1)
            else
                dist.Visible = false
            end
            
            if Config.espLine then
                line.Visible = true
                line.From = fixedPoint
                line.To = Vector2.new(cx, ty + height)
                line.Color = Color3.new(1, 1, 1)
                line.Thickness = 3
                line.Transparency = 0.3
            else
                line.Visible = false
            end
            
            if Config.espSkeleton then
                local bodyParts = {}
                local partNames = {"Head", "UpperTorso", "LowerTorso", "LeftUpperArm", "LeftLowerArm", "RightUpperArm", "RightLowerArm", "LeftUpperLeg", "LeftLowerLeg", "RightUpperLeg", "RightLowerLeg"}
                
                for _, name in pairs(partNames) do
                    local p = char:FindFirstChild(name)
                    if not p then
                        if name == "Head" then p = char:FindFirstChild("head") end
                        if name == "UpperTorso" then p = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso") end
                        if name == "LowerTorso" then p = char:FindFirstChild("LowerTorso") or char:FindFirstChild("Hip") end
                        if name == "LeftUpperArm" then p = char:FindFirstChild("LeftUpperArm") or char:FindFirstChild("LeftArm") end
                        if name == "RightUpperArm" then p = char:FindFirstChild("RightUpperArm") or char:FindFirstChild("RightArm") end
                        if name == "LeftLowerArm" then p = char:FindFirstChild("LeftLowerArm") or char:FindFirstChild("LeftForearm") end
                        if name == "RightLowerArm" then p = char:FindFirstChild("RightLowerArm") or char:FindFirstChild("RightForearm") end
                        if name == "LeftUpperLeg" then p = char:FindFirstChild("LeftUpperLeg") or char:FindFirstChild("LeftLeg") end
                        if name == "RightUpperLeg" then p = char:FindFirstChild("RightUpperLeg") or char:FindFirstChild("RightLeg") end
                        if name == "LeftLowerLeg" then p = char:FindFirstChild("LeftLowerLeg") or char:FindFirstChild("LeftCalf") end
                        if name == "RightLowerLeg" then p = char:FindFirstChild("RightLowerLeg") or char:FindFirstChild("RightCalf") end
                    end
                    if p then
                        bodyParts[name] = p
                    end
                end
                
                local jointMap = {
                    {"Head", "UpperTorso"},
                    {"UpperTorso", "LowerTorso"},
                    {"UpperTorso", "LeftUpperArm"},
                    {"LeftUpperArm", "LeftLowerArm"},
                    {"UpperTorso", "RightUpperArm"},
                    {"RightUpperArm", "RightLowerArm"},
                    {"LowerTorso", "LeftUpperLeg"},
                    {"LeftUpperLeg", "LeftLowerLeg"},
                    {"LowerTorso", "RightUpperLeg"},
                    {"RightUpperLeg", "RightLowerLeg"}
                }
                
                for i, joint in pairs(jointMap) do
                    local p1 = bodyParts[joint[1]]
                    local p2 = bodyParts[joint[2]]
                    
                    if p1 and p2 then
                        local pos1 = Camera:WorldToViewportPoint(p1.Position)
                        local pos2 = Camera:WorldToViewportPoint(p2.Position)
                        
                        if pos1.Z > 0 and pos2.Z > 0 then
                            skeletonLines[i].line.Visible = true
                            skeletonLines[i].line.From = Vector2.new(pos1.X, pos1.Y)
                            skeletonLines[i].line.To = Vector2.new(pos2.X, pos2.Y)
                            skeletonLines[i].line.Color = Color3.new(1, 1, 1)
                            skeletonLines[i].line.Thickness = 3
                            skeletonLines[i].line.Transparency = 0.3
                        else
                            skeletonLines[i].line.Visible = false
                        end
                    else
                        skeletonLines[i].line.Visible = false
                    end
                end
            else
                for _, joint in pairs(skeletonLines) do
                    joint.line.Visible = false
                end
            end
        else
            box.Visible = false
            health.Visible = false
            name.Visible = false
            dist.Visible = false
            line.Visible = false
            for _, joint in pairs(skeletonLines) do
                joint.line.Visible = false
            end
        end
    end
    
    local conn = RunService.RenderStepped:Connect(UpdateESP)
    table.insert(espObjects, conn)
end

-- ========== CHAMS ==========
local function CreateChams(player)
    if player == LocalPlayer or not player.Character then return end
    local char = player.Character
    if not char:FindFirstChild("Humanoid") then return end
    
    local hl = Instance.new("Highlight")
    hl.Parent = char
    hl.FillColor = Color3.new(1, 0, 0)
    hl.FillTransparency = 0.4
    hl.OutlineColor = Color3.new(1, 1, 1)
    hl.OutlineTransparency = 0.2
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Enabled = true
    table.insert(chamsList, hl)
end

