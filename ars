local function ClearESP()
    for i = #espObjects, 1, -1 do
        local obj = espObjects[i]
        if obj then
            pcall(function()
                if obj.Remove then obj:Remove()
                elseif obj.Disconnect then obj:Disconnect()
                end
            end)
            espObjects[i] = nil
        end
    end
    espObjects = {}
end

local function ClearChams()
    for i = #chamsList, 1, -1 do
        local obj = chamsList[i]
