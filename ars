    Callback = function(v) 
        Config.espLine = v
        if v then Config.esp = true end
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then CreateESP(p) end
        end
        SaveCurrentConfig()
    end
})

ESPTab:CreateToggle({
    Name = "Chams (Glow)",
    CurrentValue = Config.chams,
    Callback = function(v)
        Config.chams = v
        if v then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then CreateChams(p) end
            end
        else
            ClearChams()
        end
        SaveCurrentConfig()
    end
})

-- ========== SETTINGS TAB ==========
local SettingsTab = Window:CreateTab("Settings")

SettingsTab:CreateToggle({
    Name = "Streamer Mode (F1)",
    CurrentValue = Config.streamerMode,
    Callback = function(v)
        if Config.streamerMode ~= v then
            ToggleStreamerMode()
        end
    end
})

SettingsTab:CreateButton({
    Name = "Toggle Streamer Mode (F1)",
    Callback = function()
        ToggleStreamerMode()
    end
})

SettingsTab:CreateButton({
    Name = "Reset All Settings",
    Callback = function()
        Config = defaultConfig
        SaveConfig(Config)
        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "Batata Hub",
                Text = "Configurações resetadas! Recarregue o script.",
                Duration = 3
            })
        end)
    end
})

-- ========== LIMPEZA ==========
LocalPlayer.OnTeleport:Connect(function()
    ClearESP()
    ClearChams()
    if fovCircle then pcall(fovCircle.Remove, fovCircle) end
end)

print("Batata Hub carregado!")
print("LeftAlt = Aimbot")
print("F1 = Streamer Mode")
print("Configurações salvas automaticamente!")
