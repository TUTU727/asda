-- ========== LOOP PRINCIPAL ==========
RunService.RenderStepped:Connect(function()
    GetCenter()
    
    -- FOV
    if Config.fov and fovCircle and not Config.streamerMode then
        fovCircle.Visible = true
        fovCircle.Radius = Config.fovSize
        fovCircle.Position = screenCenter
        local target = GetTarget()
        fovCircle.Color = target and Color3.new(1, 0, 0) or Color3.new(0, 1, 0)
    elseif fovCircle then
        fovCircle.Visible = false
    end
    
    local shouldAim = false
    if Config.aimbot then
        if Config.aimOnShoot then
            shouldAim = isShooting or shootingHold
        else
            shouldAim = true
        end
    end
    
    if shouldAim then
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local target = GetTarget()
                if target and target.part and target.part.Parent then
                    local cf = Camera.CFrame
                    local look = (target.part.Position - cf.Position).Unit
                    local newCF = CFrame.new(cf.Position, cf.Position + look)
                    Camera.CFrame = cf:Lerp(newCF, Config.smooth)
                end
            end
        end
    end
end)

-- ========== STREAMER MODE TOGGLE (F1) ==========
local function ToggleStreamerMode()
    Config.streamerMode = not Config.streamerMode
    SaveCurrentConfig()
    
    if Config.streamerMode then
        if fovCircle then fovCircle.Visible = false end
        
        for _, obj in pairs(espObjects) do
            pcall(function()
                if obj.Visible ~= nil then
                    obj.Visible = false
                end
            end)
        end
        
        for _, obj in pairs(chamsList) do
            pcall(function()
                if obj and obj.Enabled ~= nil then
                    obj.Enabled = false
                end
            end)
        end
        
        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "Streamer Mode",
                Text = "ATIVADO ✓ - Tela limpa para stream",
                Duration = 2
            })
        end)
    else
        if Config.fov and fovCircle then
            fovCircle.Visible = true
        end
        
        for _, obj in pairs(chamsList) do
            pcall(function()
                if obj and obj.Enabled ~= nil then
                    obj.Enabled = true
                end
            end)
        end
        
        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "Streamer Mode",
                Text = "DESATIVADO ✗ - ESPs visíveis",
                Duration = 2
            })
        end)
    end
end

