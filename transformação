    Name = "🔍 Escanear Orbs",
    Callback = function()
        local orbs = FindOrbs()
        print("=== ORBS ENCONTRADAS: " .. #orbs .. " ===")
        for i, orb in ipairs(orbs) do
            print(string.format("%d. %s | Dist: %.1f", i, tostring(orb.Object), orb.Dist))
        end
        
        if #orbs == 0 then
            print("❌ Nenhuma orb encontrada!")
        end
        
        OrionLib:MakeNotification({
            Name = "Escanear",
            Content = #orbs > 0 and "✅ " .. #orbs .. " orbs encontradas!" or "❌ Nenhuma orb!",
            Image = "rbxassetid://4483345998",
            Time = 3
        })
    end
})

MainTab:AddButton({
    Name = "🚀 Teleportar para Orb",
    Callback = function()
        local orbs = FindOrbs()
        if #orbs > 0 then
            local char = LocalPlayer.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    pcall(function()
                        root.CFrame = CFrame.new(orbs[1].Pos)
                    end)
                    OrionLib:MakeNotification({
                        Name = "Teleporte",
                        Content = "✅ Teleportado para a orb!",
                        Image = "rbxassetid://4483345998",
                        Time = 2
                    })
                end
            end
        else
            OrionLib:MakeNotification({
                Name = "Erro",
                Content = "❌ Nenhuma orb encontrada!",
                Image = "rbxassetid://4483345998",
                Time = 2
            })
        end
    end
})

MainTab:AddButton({
    Name = "ℹ️ Como usar",
    Callback = function()
        OrionLib:MakeNotification({
            Name = "Como usar",
            Content = "1. Ative o toggle\n2. O script vai procurar orbs\n3. Teleporta e coleta automaticamente",
            Image = "rbxassetid://4483345998",
            Time = 5
        })
    end
})

